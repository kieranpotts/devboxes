# ------------------------------------------------------------------------------
# The `.gitattributes` file tells the Git source control system what settings to
# automatically apply when handling various file types.
# ------------------------------------------------------------------------------

# Auto detect text files and normalize line-endings to Unix format, in both the
# remote repository and the local working directory.
* text=auto eol=lf

# Exclude these files and directories from zipped archives of the repository.
.editorconfig export-ignore
.gitattributes export-ignore
.gitignore export-ignore
